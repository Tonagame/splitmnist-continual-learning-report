     return eval_cb if (visdom is not None) or (plotting_dict is not None) else None
 
 
+def _eval_history_cb(log, test_datasets, file_path, method, iters_per_context=None, test_size=None,
+                     all_contexts=True, S='mean'):
+    """Write evaluation-history rows to CSV during training.
+
+    This callback is intentionally file-based so long Phase-1 runs leave a
+    recoverable learning curve even if a later method fails.
+    """
+    if file_path is None:
+        return None
+    os.makedirs(os.path.dirname(file_path), exist_ok=True)
+    if not os.path.exists(file_path):
+        with open(file_path, "w", newline="") as f:
+            writer = csv.DictWriter(f, fieldnames=["method", "iteration", "context", "accuracy"])
+            writer.writeheader()
+
+    def eval_cb(classifier, batch, context=1):
+        iteration = batch if (context is None or context == 1) else (context - 1) * iters_per_context + batch
+        if iteration % log != 0:
+            return
+        if (S is not None) and hasattr(classifier, 'S'):
+            classifier.S = S
+        n_contexts = len(test_datasets) if all_contexts else context
+        if getattr(classifier, "scenario", None) == "task":
+            n_contexts = context
+        accs = []
+        for i in range(n_contexts):
+            allowed_classes = None
+            if getattr(classifier, "scenario", None) == "task" and not getattr(classifier, "singlehead", False):
+                classes_per_context = getattr(classifier, "classes_per_context", None)
+                if classes_per_context is not None:
+                    allowed_classes = list(range(classes_per_context * i, classes_per_context * (i + 1)))
+            accs.append(
+                evaluate.test_acc(
+                    classifier, test_datasets[i], batch_size=128, test_size=test_size,
+                    verbose=False, context_id=i, allowed_classes=allowed_classes
+                )
+            )
+        with open(file_path, "a", newline="") as f:
+            writer = csv.DictWriter(f, fieldnames=["method", "iteration", "context", "accuracy"])
+            writer.writerow({
+                "method": method or getattr(classifier, "label", "model"),
+                "iteration": iteration,
+                "context": context,
+                "accuracy": sum(accs) / len(accs),
+            })
+
+    return eval_cb
+
+
